  "version": "0.2.0",
  "configurations": [
    {
      "type": "chrome",
      "request": "launch",
      "name": "Chrome: Zorvexa site (starts server on :8080)",
      "url": "http://127.0.0.1:8080",
      "webRoot": "${workspaceFolder}",
      "preLaunchTask": "serve-static"
    },
    {
      "type": "chrome",
      "request": "launch",
      "name": "Chrome: Zorvexa site (server already running)",
      "url": "http://127.0.0.1:8080",
      "webRoot": "${workspaceFolder}"
    }
  ]
}
